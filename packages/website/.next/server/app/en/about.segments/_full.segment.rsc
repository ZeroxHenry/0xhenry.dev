9:["$","section",null,{"className":"max-w-3xl mx-auto px-5 py-16","children":[["$","h1",null,{"className":"text-4xl font-black mb-6","children":"I believe everyone should be able to build and understand robots."}],["$","div",null,{"className":"space-y-4 text-lg text-gray-700 dark:text-gray-300 leading-relaxed","children":[["$","p",null,{"children":"Hey, I'm Henry. I'm an engineer dedicated to a future where robot education isn't locked behind a PhD or a corporate wall."}],["$","p",null,{"children":"Moving toward a world where robots are common as smartphones, yet their education remains opaque. This platform bridges that gap by documenting real engineering learning."}]]}],["$","h2",null,{"className":"text-2xl font-bold mt-12 mb-3","children":"Our Focus"}],["$","p",null,{"className":"text-gray-700 dark:text-gray-300 leading-relaxed","children":"Robot Education for Everyone, AI Vision & Intelligence, Biomechanical Modeling, and the Future of Learning."}],["$","h2",null,{"className":"text-2xl font-bold mt-12 mb-3","children":"The Philosophy"}],["$","p",null,{"className":"text-gray-700 dark:text-gray-300 leading-relaxed","children":"No corporate fluff. No jargon for the sake of jargon. Just the engineering vision and the steps to get there. Whether you're a non-expert or a builder, you'll find a partner here."}]]}]
