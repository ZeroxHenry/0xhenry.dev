{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/[lang]/layout,_N_T_/[lang]/login/layout,_N_T_/[lang]/login/page,_N_T_/ko/login"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/$d$lang/login/__PAGE__",
    "/$d$lang/login",
    "/$d$lang",
    "/_index",
    "/_head"
  ]
}