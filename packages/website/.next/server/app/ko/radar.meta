{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/[lang]/layout,_N_T_/[lang]/radar/layout,_N_T_/[lang]/radar/page,_N_T_/ko/radar"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/$d$lang/radar/__PAGE__",
    "/$d$lang/radar",
    "/$d$lang",
    "/_index",
    "/_head"
  ]
}